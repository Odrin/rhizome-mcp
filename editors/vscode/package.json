{
  "name": "rhizome-mcp",
  "displayName": "Rhizome MCP",
  "description": "Bundles the rhizome-mcp server as a VS Code MCP provider for local issue tracking, planning, and agent workflows.",
  "version": "0.0.1",
  "publisher": "odrin",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Odrin/rhizome-mcp.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "agents",
    "task tracking",
    "copilot",
    "claude",
    "codex"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#f5f8fc",
    "theme": "light"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "rhizome-mcp.init",
        "title": "Rhizome: Initialize Project"
      },
      {
        "command": "rhizome-mcp.showBoard",
        "title": "Rhizome: Open Status Board"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "rhizome-mcp.servers",
        "label": "Rhizome MCP"
      }
    ],
    "configuration": {
      "title": "Rhizome MCP",
      "properties": {
        "rhizome.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the rhizome-mcp binary. Leave empty to use the binary bundled with this extension or fall back to PATH."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . --outDir out --watch",
    "pretest": "npm run compile-tests && npm run build && npm run lint",
    "test": "vscode-test",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "package": "npm run build -- --production && vsce package",
    "package:local": "node scripts/package-platforms.mjs --local"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.101.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
